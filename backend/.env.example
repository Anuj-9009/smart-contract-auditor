# ═══════════════════════════════════════════════════════════
# Smart Contract Auditor AI — Environment Configuration
# Zero-Cost Stack: Ollama/Groq + Supabase/SQLite
# ═══════════════════════════════════════════════════════════

# ─── LLM Provider (pick one — priority: Ollama > Groq > Claude > OpenAI) ───

# Ollama — FREE, runs locally.
# Install: https://ollama.com
OLLAMA_MODEL=qwen2.5-coder

# Groq — FREE tier, cloud inference. 
# Get key: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Database (pick one) ───────────────────────────────────

# Supabase — FREE PostgreSQL cloud DB
# Get from: https://supabase.com → New Project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJh...your_anon_key_here

# SQLite fallback (used automatically if Supabase not configured)
DATABASE_URL=sqlite:///./auditor.db

# ─── Environment ──────────────────────────────────────────
ENVIRONMENT=development
